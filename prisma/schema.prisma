generator client {
  provider = "prisma-client-js"
}

// ── Production: PostgreSQL (Supabase) ──

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  emailVerified       DateTime?
  password            String?
  image               String?
  role                String               @default("owner")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  organization        OrganizationMember[]
  attendance          Attendance[]
  sentInvitations     TeamInvitation[]     @relation("Inviter")
  notifications       Notification[]
  assignedTasks       TeamTask[]
  valtrioxTeamMembers ValtrioxTeamMember[]
  otpCode             String?
  otpExpires          DateTime?
  otpVerified         Boolean              @default(false)

  @@index([role])
}

model Organization {
  id                    String                  @id @default(cuid())
  name                  String
  slug                  String                  @unique
  logo                  String? // Base64 or URL
  website               String?
  phone                 String?
  email                 String?
  currency              String                  @default("USD")
  timezone              String                  @default("UTC")
  plan                  String                  @default("starter")
  workingHoursStart     String                  @default("09:00") // e.g. "09:00"
  workingHoursEnd       String                  @default("18:00") // e.g. "18:00"
  isActive              Boolean                 @default(true)
  // ── Brand Settings (persisted to DB) ──
  country               String?
  religion              String?
  brandTagline          String?
  brandColor            String? // Primary brand color hex
  secondaryBrandColor   String? // Secondary brand color hex
  brandDescription      String?
  industry              String? // Industry/niche: E-Commerce, Fashion, Tech, Food, Services, Education, Healthcare, Real Estate, Other
  address               String?
  taxId                 String?
  favicon               String? // Base64 or URL
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  members               OrganizationMember[]
  invitations           TeamInvitation[]
  products              Product[]
  orders                Order[]
  customers             Customer[]
  expenses              Expense[]
  coupons               Coupon[]
  teamTasks             TeamTask[]
  subscription          Subscription?
  notifications         Notification[]
  paymentProofs         PaymentProof[]
  invoices              Invoice[]
  reportExports         ReportExport[]
  attendance            Attendance[]
  integrations          IntegrationConnection[]
  feedbacks             Feedback[]
  platformDocuments     PlatformDocument[]
  // ── Phase 3: Client Communication Center ──
  clientMessages        ClientMessage[]
  // ── Phase 18: AI Workforce / AI Team Module ──
  aiAgents              AiAgent[]
  aiTasks               AiTask[]
  aiMessages            AiMessage[]
  aiMemories            AiMemory[]
  aiWorkflows           AiWorkflow[]
  aiWorkflowExecutions  AiWorkflowExecution[]
  aiActionLogs          AiActionLog[]
  aiApprovalRequests    AiApprovalRequest[]
  aiAutomationRules     AiAutomationRule[]
  // ── Atomic Counters (race-safe via increment) ──
  orderCounter          Int                     @default(0) // Monotonic counter for VTX-XXXX order numbers
  // ── Billing Security ──
  paymentRejectionCount Int                     @default(0) // Track fake payment rejections
  isBanned              Boolean                 @default(false)
  banReason             String?
  bannedAt              DateTime?
  // ── Usage Tracking (for plan limits) ──
  usageOrdersCount      Int                     @default(0)
  usageProductsCount    Int                     @default(0)
  usageCustomersCount   Int                     @default(0)
  usageStorageMb        Int                     @default(0)
  usageInvoicesCount    Int                     @default(0)
  usageCouponsCount     Int                     @default(0)
  usageTasksCount       Int                     @default(0)
  usageTeamChatsCount   Int                     @default(0)
  usageBroadcastsCount  Int                     @default(0)
  usageLastResetAt      DateTime?

  @@index([plan])
  @@index([isActive])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member")
  roleId         String?
  pin            String? // Team member login PIN (6-digit, bcrypt hashed)
  pinCreatedAt   DateTime? // When PIN was generated
  absenceCount   Int          @default(0) // Consecutive absences for penalty
  penaltyUntil   DateTime? // If penalized, access restricted until this date
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleDef        Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([organizationId, role])
}

model Product {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  sku            String?
  price          Decimal      @default(0) @db.Decimal(10, 2)
  costPrice      Decimal?     @db.Decimal(10, 2)
  stock          Int          @default(0)
  category       String?
  status         String       @default("active")
  imageUrl       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]

  @@index([organizationId, status])
  @@index([organizationId, category])
  @@index([organizationId, createdAt])
  @@index([organizationId, stock])
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  city           String?
  address        String?
  loyaltyTier    String       @default("new")
  totalSpent     Decimal      @default(0) @db.Decimal(10, 2)
  orderCount     Int          @default(0)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@index([organizationId, loyaltyTier])
  @@index([organizationId, totalSpent])
  @@index([organizationId, createdAt])
  @@index([organizationId, email])
}

model Order {
  id             String       @id @default(cuid())
  orderNumber    String
  organizationId String
  customerId     String?
  status         String       @default("pending")
  subtotal       Decimal      @default(0) @db.Decimal(10, 2)
  discount       Decimal      @default(0) @db.Decimal(10, 2)
  total          Decimal      @default(0) @db.Decimal(10, 2)
  channel        String       @default("manual")
  courier        String?
  trackingNumber String?
  notes          String?
  priority       Int          @default(50)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          OrderItem[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([organizationId, customerId])
  @@index([channel])
  @@index([orderNumber])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String? // Nullable for onDelete: SetNull
  productName String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model Expense {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  amount         Decimal      @db.Decimal(10, 2)
  category       String
  date           DateTime
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([organizationId, category])
}

model Coupon {
  id             String       @id @default(cuid())
  organizationId String
  code           String
  type           String       @default("percentage")
  value          Decimal      @db.Decimal(10, 2)
  minOrder       Decimal?     @db.Decimal(10, 2)
  usageLimit     Int?
  usageCount     Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@index([organizationId, expiresAt])
}

model TeamTask {
  id             String       @id @default(cuid())
  organizationId String
  assignedTo     String?
  title          String
  description    String?
  status         String       @default("todo")
  priority       String       @default("medium")
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedToUser User?        @relation(fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, priority])
  @@index([assignedTo])
  @@index([organizationId, dueDate])
}

model Attendance {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  date           DateTime
  clockIn        DateTime?
  clockOut       DateTime?
  totalHours     Float?
  status         String       @default("present")
  lateReason     String? // Required if clocked in late
  leaveReason    String? // Required if on leave
  markedBy       String? // "self" or "admin"
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, date])
  @@index([organizationId, date])
  @@index([organizationId, status])
  @@index([userId, date])
}

// ── Subscription Plans ──
model SubscriptionPlan {
  id             String         @id @default(cuid())
  name           String         @unique
  price          Decimal        @db.Decimal(10, 2)
  annualPrice    Decimal        @default(0) @db.Decimal(10, 2) // Annual pricing (0 = no annual discount)
  quarterlyPrice Decimal        @default(0) @db.Decimal(10, 2) // Quarterly pricing (0 = no quarterly discount)
  period         String         @default("monthly")
  features       String         @default("[]")
  teamLimit      Int            @default(3)
  orderLimit     Int            @default(100)
  productLimit   Int            @default(50)
  isActive       Boolean        @default(true)
  trialDays      Int            @default(14)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
  paymentProofs  PaymentProof[]
}

// ── Organization Subscription ──
model Subscription {
  id               String           @id @default(cuid())
  organizationId   String           @unique
  planId           String
  status           String           @default("trial") // trial, active, pending_payment, expired, cancelled
  billingCycle     String           @default("monthly") // monthly, annually
  trialStartsAt    DateTime         @default(now())
  trialEndsAt      DateTime
  currentPeriodEnd DateTime?
  // ── Renewal Reminder Tracking ──
  lastReminderAt   DateTime?
  reminderCount    Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan             SubscriptionPlan @relation(fields: [planId], references: [id])
  payments         PaymentProof[]
  invoices         Invoice[]

  @@index([status])
  @@index([organizationId, status])
}

// ── Invoices (PDF trackable records) ──
model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  organizationId String
  subscriptionId String?
  paymentProofId String?
  planName       String
  amount         Decimal       @db.Decimal(10, 2)
  billingCycle   String        @default("monthly")
  status         String        @default("pending") // draft, pending, sent, paid, approved, overdue, cancelled, refunded
  type           String        @default("subscription") // subscription, order, custom
  currencyCode   String        @default("PKR")
  currencySymbol String        @default("Rs.")
  issuedAt       DateTime      @default(now())
  dueDate        DateTime?
  paidAt         DateTime?
  periodStart    DateTime?
  periodEnd      DateTime?
  notes          String?
  pdfUrl         String? // stored PDF path if generated
  orgName        String?
  orgEmail       String?
  orgPhone       String?
  orgAddress     String?

  // ── Phase 2: Custom Invoice + Payment Approval Workflow ──
  lineItems      Json?         // [{ description, qty, rate, amount }] for custom invoices
  subtotal       Decimal?      @db.Decimal(12, 2)
  taxRate        Decimal?      @db.Decimal(5, 2)  // percentage, e.g. 13.00
  taxAmount      Decimal?      @db.Decimal(10, 2)
  discountAmount Decimal?      @db.Decimal(10, 2)
  clientEmail    String?       // for invoices sent to clients outside the org record
  clientName     String?       // client name (free-text, e.g. "Acme Pvt Ltd")
  clientAddress  String?       // client billing address
  approvedBy     String?       // UserId of platform admin who approved payment
  approvedAt     DateTime?     // when admin approved
  sentAt         DateTime?     // when invoice was emailed to client
  createdBy      String?       // UserId of creator (admin or auto)
  invoiceTitle   String?       // custom title, e.g. "Q3 Consulting Services"
  paymentStatus  String?       // unpaid, pending_verification, verified, rejected

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  paymentProof   PaymentProof? @relation(fields: [paymentProofId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@index([organizationId, status])
  @@index([type])
  @@index([paymentStatus])
}

// ── Phase 2: Report Export Audit Trail ──
// Tracks every report PDF generated + emailed to clients from inside Valtriox
model ReportExport {
  id             String       @id @default(cuid())
  organizationId String
  type           String       // sales | orders | customer_statement | inventory | tax | custom_range
  title          String       // display title (e.g. "Sales Report - January 2027")
  period         String       // daily | weekly | monthly | quarterly | yearly | custom
  dateFrom       DateTime?
  dateTo         DateTime?
  pdfUrl         String?      // if stored (otherwise on-demand generated)
  generatedById  String?      // UserId of admin who generated
  recipientEmail String?      // client email if emailed
  emailedAt      DateTime?
  emailStatus    String?      // sent | failed | pending
  fileSizeKb     Int?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
  @@index([createdAt])
}

// ── Phase 3: Client Communication Center ──────────────────────────────────
// Premium threaded messaging system between Valtriox admin (Muhammad Ashir
// Raza) and his clients. Supports categories: monthly deadlines, subscription
// plan features sharing, document sharing, improvements feedback, invoices,
// reports, and general professional communication.
model ClientMessage {
  id              String   @id @default(cuid())
  organizationId  String   // client org this conversation belongs to

  // ── Threading ──
  threadId        String   // shared by all messages in a conversation
                           // (auto-generated from first message, format: "thread_<cuid>")
  parentMessageId String?  // direct reply target (for nested replies)

  // ── Direction & Sender ──
  direction       String   // "admin_to_client" | "client_to_admin"
  senderUserId    String?  // UserId of sender (admin or client user)
  senderName      String   // display name (e.g. "Muhammad Ashir Raza")
  senderEmail     String   // display email
  senderRole      String   // platform_owner | platform_admin | brand_owner | etc.
  senderAvatar    String?  // optional avatar URL/base64

  // ── Content ──
  category        String   // deadline | subscription_features | document |
                           // improvements | invoice | report | general | onboarding | billing
  subject         String   // short subject line
  body            String   // markdown / plain text body
  attachments     Json?    // [{ name, url, size, type }] — file metadata
  priority        String   @default("normal") // low | normal | high | urgent

  // ── Phase 16: Action Buttons & Message Metadata ──
  // actions: array of { id, label, type, payload, style }
  //   type ∈ renew_subscription | upload_payment_proof | view_invoice |
  //         view_report | open_billing | dismiss | custom_url
  //   payload: { planId?, amount?, billingCycle?, invoiceId?, url? }
  //   style: primary | secondary | danger | ghost (default: primary)
  // Example:
  //   [{ id:"btn_renew", label:"Renew Subscription Now",
  //      type:"renew_subscription", payload:{ planId:"growth", amount:4999, billingCycle:"monthly" },
  //      style:"primary" }]
  actions         Json?
  // metadata: free-form key/value pairs for analytics & state tracking
  //   e.g. { sourceTemplate:"renewal_reminder_v1", actionState:"pending|clicked|completed" }
  metadata        Json?
  // isSystemMessage: marks messages sent by "Valtriox System" (senderUserId=null,
  // senderName="Valtriox System", senderRole="system"). Visually distinct in UI
  // (gold system badge, no admin avatar). Default false.
  isSystemMessage Boolean  @default(false)

  // ── Status ──
  isReadByAdmin   Boolean  @default(false)
  isReadByClient  Boolean  @default(false)
  readAt          DateTime?
  isPinned        Boolean  @default(false)  // admin can pin important threads
  isArchived      Boolean  @default(false)

  // ── Scheduling & Expiry ──
  scheduledFor    DateTime?  // for scheduled deadline reminders (null = sent immediately)
  deadlineDate    DateTime?  // for "deadline" category — actual deadline date
  sentAt          DateTime   @default(now())

  // ── Related Entities (optional cross-links) ──
  relatedInvoiceId String?
  relatedReportId  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, direction])
  @@index([organizationId, category])
  @@index([threadId])
  @@index([scheduledFor])
  @@index([isArchived])
  @@index([createdAt])
}

// ── Payment Proofs ──
model PaymentProof {
  id             String            @id @default(cuid())
  subscriptionId String
  organizationId String
  planId         String? // FK to SubscriptionPlan (for robustness)
  planName       String
  amount         Decimal           @db.Decimal(10, 2)
  billingCycle   String            @default("monthly") // monthly, annually
  transactionId  String // app-level uniqueness enforced in payment route transaction
  paymentMethod  String            @default("bank_transfer")
  screenshotUrl  String?
  status         String            @default("pending")
  adminNote      String?
  // Phase 16: client-submitted plan details (free text). Required by the
  // new Communication-Centre action-button payment flow. Admin sees this in
  // the payment approval panel to verify the client paid for the right plan.
  clientNote     String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  subscription   Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plan           SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  invoices       Invoice[]

  @@index([organizationId])
  @@index([status])
  @@index([subscriptionId])
}

// ── Notification (Push + In-App) ──
model Notification {
  id        String   @id @default(cuid())
  orgId     String?
  userId    String?
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error, order, team, marketing
  actionUrl String? // optional link to navigate to
  icon      String? // optional icon name
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
  @@index([userId, read])
  @@index([orgId, read])
}

// ── Lead Capture (Contact Form Submissions) ──
model Lead {
  id                  String    @id @default(cuid())
  fullName            String
  email               String
  phone               String?
  company             String?
  companySize         String?
  industry            String?
  interest            String?
  message             String?
  // ── Consultation Scheduling ──
  consultationType    String? // video_call, phone_call, in_person
  preferredDate       String? // e.g. "2026-06-15"
  preferredTime       String? // e.g. "09:00-12:00", "12:00-15:00", "15:00-18:00", "18:00-21:00"
  timezone            String? // e.g. "Asia/Karachi"
  availabilityNote    String? // Additional availability notes
  calendlyBookingLink String? // Calendly scheduled meeting URI
  // ── Status & Source ──
  status              String    @default("new") // new, contacted, qualified, consultation_scheduled, proposal_sent, converted, archived
  source              String    @default("website") // website, referral, social, ads
  notes               String?
  // ── Follow-Up Tracking ──
  lastFollowUpAt      DateTime?
  followUpCount       Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  proposals Proposal[]

  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@index([status, createdAt])
}

// ── Proposals (Post-Consultation Client Deliverables) ──
model Proposal {
  id             String    @id @default(cuid())
  leadId         String?
  clientName     String
  clientEmail    String
  clientCompany  String?
  clientPhone    String?
  type           String // brand_management, digital_marketing, tech_integration, e_commerce, enterprise, monthly_retainer
  title          String
  status         String    @default("draft") // draft, sent, viewed, accepted, rejected, expired, revised
  totalCost      Decimal?  @db.Decimal(10, 2)
  currency       String    @default("PKR")
  currencySymbol String    @default("Rs.")
  validUntil     DateTime?
  content        String    @default("{}") // JSON: proposal-specific data
  notes          String?
  sentAt         DateTime?
  viewedAt       DateTime?
  respondedAt    DateTime?
  // ── PayPro Payment Integration ──
  payproOrderId  String?
  paymentStatus  String    @default("unpaid") // unpaid, pending, paid, failed, refunded
  paidAt         DateTime?
  paymentAmount  Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lead           Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status])
  @@index([type])
  @@index([clientEmail])
  @@index([createdAt])
  @@index([paymentStatus])
}

// ── Admin Settings (Platform Owner) ──
model PlatformSettings {
  id                  String   @id @default(cuid())
  companyName         String   @default("Valtriox")
  companyEmail        String
  companyPhone        String?
  companyWebsite      String?
  companyAddress      String?
  supportHours        String   @default("Mon-Fri: 9AM-6PM PKT")
  whatsappNumber      String?
  instagramUrl        String?
  facebookUrl         String?
  twitterUrl          String?
  linkedinUrl         String?
  discordUrl          String?
  redditUrl           String?
  youtubeUrl          String?
  tiktokUrl           String?
  socialLinksVisible  String   @default("true")
  // ── Individual Platform Visibility Toggles ──
  showInstagram       Boolean  @default(false)
  showFacebook        Boolean  @default(false)
  showTwitter         Boolean  @default(false)
  showLinkedin        Boolean  @default(false)
  showDiscord         Boolean  @default(false)
  showReddit          Boolean  @default(false)
  showYoutube         Boolean  @default(false)
  showTiktok          Boolean  @default(false)
  showWhatsApp        Boolean  @default(false)
  paymentMethods      String   @default("[]")
  currency            String   @default("PKR")
  logoUrl             String?
  faviconUrl          String?
  founderImageUrl     String?
  founderBio          String?
  primaryBrandColor   String   @default("#059669")
  secondaryBrandColor String   @default("#d97706")
  currencySymbol      String   @default("Rs.")
  customCss           String   @default("")
  tagline             String   @default("Premium Brand Management Portal")
  emailFooterText     String?
  invoiceHeaderText   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ── Role Definitions ──
model Role {
  id          String               @id @default(cuid())
  name        String               @unique
  label       String
  description String?
  permissions String               @default("{}")
  level       Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     OrganizationMember[]
}

// ── Team Invitations ──
model TeamInvitation {
  id             String       @id @default(cuid())
  organizationId String
  inviterId      String
  inviteeEmail   String
  inviteeName    String
  role           String       @default("member")
  roleId         String?
  pin            String // 6-digit login PIN (bcrypt hashed)
  status         String       @default("pending") // pending, accepted, expired, revoked
  invitedAt      DateTime     @default(now())
  acceptedAt     DateTime?
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User         @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([inviteeEmail])
  @@index([status])
  @@index([organizationId, status])
  @@index([expiresAt])
}

// ── System Settings (Key-Value Store) ──
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("system")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Legal Page Content ──
model LegalPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @default("")
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ── Platform Documents (Uploaded Files - PDFs, Images, etc.) ──
// Stores metadata for files uploaded by platform admin (Cloudinary-backed).
// Text-based documents are stored in SystemSetting (category: "documents").
// This model is for binary/file uploads that go to Cloudinary storage.
model PlatformDocument {
  id                 String   @id @default(cuid())
  title              String
  description        String?  @db.Text
  fileName           String
  fileSize           Int // bytes
  mimeType           String
  fileType           String   @default("document") // pdf, image, spreadsheet, document, archive
  cloudinaryUrl      String? // Full CDN URL
  cloudinaryPublicId String? // For deletion
  category           String   @default("uploaded") // uploaded, lead-magnet, proposal-export, invoice-template
  isActive           Boolean  @default(true)
  uploadedBy         String? // userId
  organizationId     String? // org that owns this file — prevents cross-org access
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([isActive])
  @@index([fileType])
  @@index([organizationId])
}

// ── Valtriox Team (Platform-level team, separate from brand teams) ──
model ValtrioxTeamMember {
  id              String    @id @default(cuid())
  userId          String    @unique
  email           String
  name            String
  role            String    @default("platform_admin")
  department      String?
  status          String    @default("active")
  invitedBy       String?
  joinedAt        DateTime  @default(now())
  lastActive      DateTime?
  visibleSections String    @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([department])
}

model ValtrioxTeamInvitation {
  id         String    @id @default(cuid())
  email      String
  name       String
  role       String    @default("platform_admin")
  department String?
  invitedBy  String?
  token      String    @unique
  status     String    @default("pending")
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  acceptedAt DateTime?
  // invitedBy stores User IDs (not TeamMember IDs), so no FK relation
  // was causing FK violation during prisma db push

  @@index([email])
  @@index([status])
}

// ── Support Chat: Client Conversations ──
// Tracks which organizations have active support conversations
model SupportConversation {
  id             String   @id @default(cuid())
  organizationId String   @unique // One conversation per organization
  orgName        String // Cached org name for admin display
  lastMessage    String   @default("")
  lastMessageAt  DateTime @default(now())
  unreadAdmin    Int      @default(0) // Unread count for admin (messages from client)
  unreadClient   Int      @default(0) // Unread count for client (messages from admin)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages SupportMessage[]

  @@index([lastMessageAt])
}

// ── Support Chat: Messages ──
model SupportMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String // User ID or "system" / "admin-valtriox"
  senderName     String
  senderAvatar   String?
  senderRole     String   @default("member")
  content        String   @default("")
  messageType    String   @default("text") // text, system, attachment, voice, call
  attachmentData String? // JSON: { id, name, type, size, url }
  voiceNoteData  String? // JSON: { id, url, duration }
  callInfoData   String? // JSON: { duration, type }
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ── Email Templates (editable auto-email templates) ──
model EmailTemplate {
  id          String   @id @default(cuid())
  type        String   @unique // lead_welcome, lead_follow_up, consultation_reminder, proposal_sent, thank_you, custom
  name        String // Human-readable name
  subject     String // Email subject line
  htmlContent String // Full HTML email template
  textContent String   @default("") // Plain text fallback
  variables   String   @default("[]") // JSON: available variables e.g. ["{{leadName}}", "{{companyName}}"]
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  automations Automation[]
}

// ── Automations (auto-email triggers & scheduling) ──
model Automation {
  id            String         @id @default(cuid())
  name          String
  description   String?
  trigger       String // lead_created, consultation_scheduled, proposal_sent, status_changed, manual
  triggerConfig String         @default("{}") // JSON: trigger-specific config
  templateId    String? // FK to EmailTemplate
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  action        String         @default("send_email") // send_email, send_whatsapp, notify_admin
  actionConfig  String         @default("{}") // JSON: action-specific config
  delayMinutes  Int            @default(0) // Delay before action (0 = immediate)
  enabled       Boolean        @default(true)
  lastRunAt     DateTime?
  runCount      Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([enabled])
  @@index([trigger])
}

// ── Integration Connections ──
// Stores real third-party integration configs per organization.
// Each org can have one connection per integration type (e.g., one Shopify, one Stripe).
model IntegrationConnection {
  id             String    @id @default(cuid())
  organizationId String
  type           String // e.g., "mailchimp", "shopify", "stripe", "whatsapp-api"
  provider       String // e.g., "email_marketing", "ecommerce", "payments", "communication"
  name           String // Human-readable: "Shopify Store", "Stripe Payments"
  status         String    @default("disconnected") // connected, disconnected, error, pending
  config         String?   @db.Text // JSON string: API keys, webhook URLs, tokens (encrypted at rest via DB SSL)
  metadata       String?   @db.Text // JSON string: extra data (webhook id, sync cursor, etc.)
  connectedAt    DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@index([organizationId])
  @@index([type])
  @@index([status])
}

// ── Feedback & Testimonials Collection ──
model Feedback {
  id             String       @id @default(cuid())
  organizationId String
  type           String // "feedback" | "testimonial" | "review" | "video"
  rating         Int? // 1-5 for reviews/testimonials
  content        String // The feedback/review text
  authorName     String? // Name of the person giving feedback
  authorCompany  String? // Their company/brand name
  videoUrl       String? // URL for video testimonials
  isFeatured     Boolean      @default(false) // For landing page display
  status         String       @default("pending") // pending | approved | rejected
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@index([status])
}

// ── Beta Invites (Platform Admin) ──
model BetaInvite {
  id         String    @id @default(cuid())
  email      String    @unique
  token      String    @unique // 8-char alphanumeric code for secure claim URL
  plan       String    @default("enterprise") // "enterprise" | "professional" | "growth" | "starter"
  invitedBy  String // platform_owner user id
  status     String    @default("sent") // sent | accepted | expired | revoked
  trialDays  Int       @default(14)
  expiresAt  DateTime?
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([invitedBy])
}

// ── Push Subscriptions (Web Push) ──
model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  orgId      String?
  endpoint   String   @unique
  keysAuth   String
  keysP256dh String
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([orgId])
}

// ============================================================================
// Phase 18 — AI Workforce / AI Team Module
// ============================================================================
// Multi-tenant: every model is scoped to an organizationId. The platform_owner
// (SYSTEM org) manages the master agent templates; client orgs get their own
// agent instances that operate within their tenant boundary.
//
// All AI actions are logged with timestamps + reasons (AiActionLog) for full
// auditability. Sensitive actions require explicit Owner approval
// (AiApprovalRequest) before execution.
// ============================================================================

// ── AI Agent Definition ──
// One row per agent type per organization. Seeded on first run via
// /api/ai-team/seed. Owner can start/stop, change goals, set spending limits.
model AiAgent {
  id              String    @id @default(cuid())
  organizationId  String
  // Stable identifier across orgs: "ceo", "operations", "support", etc.
  agentKey        String
  name            String                    // Display name: "CEO Agent"
  role            String                    // Functional role description
  description     String    @default("")
  // active | paused | error
  status          String    @default("active")
  // idle | busy | waiting | error — runtime status (separate from enabled flag)
  runtimeStatus   String    @default("idle")
  avatar          String?                   // Optional emoji or image URL
  // Free-form goal text set by the Owner — guides agent's decision-making
  goals           String    @default("")
  // JSON: per-agent config (e.g., max daily spend, allowed actions, escalation rules)
  config          String    @default("{}") @db.Text
  // JSON: spending limits — { daily: number, monthly: number, perAction: number }
  spendingLimits  String    @default("{}") @db.Text
  // JSON: list of action types that require Owner approval before execution
  approvalRequiredActions String @default("[]") @db.Text
  // Auto-resume on error after N seconds (0 = never)
  autoResumeAfter Int       @default(300)
  lastActiveAt    DateTime?
  lastError       String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks           AiTask[]
  sentMessages    AiMessage[] @relation("MessageFromAgent")
  receivedMessages AiMessage[] @relation("MessageToAgent")
  memoryEntries   AiMemory[]
  actionLogs      AiActionLog[]
  approvalRequests AiApprovalRequest[] @relation("ApprovalRequestedBy")
  workflowSteps   AiWorkflowStep[]

  @@unique([organizationId, agentKey])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([agentKey])
}

// ── AI Task ──
// A discrete unit of work assigned to an agent. Can be auto-generated by the
// orchestrator, by a workflow step, or manually created by the Owner.
model AiTask {
  id              String    @id @default(cuid())
  organizationId  String
  agentId         String
  // workflow_execution | manual | scheduled | escalated | system_event
  source          String    @default("manual")
  // Reference to workflow execution if source = "workflow_execution"
  workflowExecutionId String?
  title           String
  description     String    @default("") @db.Text
  // JSON: structured input data for the task
  input           String    @default("{}") @db.Text
  // JSON: structured output data (result of agent's work)
  output          String    @default("{}") @db.Text
  // pending | in_progress | completed | failed | blocked | cancelled
  status          String    @default("pending")
  // low | normal | high | urgent
  priority        String    @default("normal")
  // Business impact score 0-100 for prioritization (higher = more impactful)
  impactScore     Int       @default(50)
  // Reasoning/justification logged by the agent for auditability
  reasoning       String    @default("") @db.Text
  // If the task requires Owner approval, link to the approval request
  approvalRequestId String?
  // Auto-escalate to Owner if not completed by this time
  deadlineAt      DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  // Duration in milliseconds (set when completed)
  durationMs      Int?
  errorMessage    String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agent           AiAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvalRequest AiApprovalRequest? @relation("ApprovalForTask", fields: [approvalRequestId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([agentId, status])
  @@index([organizationId, priority])
  @@index([workflowExecutionId])
  @@index([deadlineAt])
}

// ── AI Message Bus ──
// Structured agent-to-agent communication. Every message is logged for the
// Owner to inspect. Supports request/response patterns via parentMessageId.
model AiMessage {
  id              String    @id @default(cuid())
  organizationId  String
  fromAgentId     String
  toAgentId       String
  // Type of message — determines schema of `payload`
  // request_metrics | notify_event | ask_question | share_data | escalate | broadcast
  type            String
  // Short subject (e.g., "Request campaign metrics for Q3")
  subject         String
  // JSON: structured payload — varies by `type`
  payload         String    @default("{}") @db.Text
  // For threaded conversations
  parentMessageId String?
  // Whether the recipient agent has processed this message
  isProcessed     Boolean   @default(false)
  processedAt     DateTime?
  // Optional reply payload (set when recipient responds)
  reply           String?   @db.Text
  sentAt          DateTime  @default(now())
  createdAt       DateTime  @default(now())

  fromAgent       AiAgent   @relation("MessageFromAgent", fields: [fromAgentId], references: [id], onDelete: Cascade)
  toAgent         AiAgent   @relation("MessageToAgent", fields: [toAgentId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, sentAt])
  @@index([fromAgentId])
  @@index([toAgentId, isProcessed])
  @@index([parentMessageId])
}

// ── AI Memory / Knowledge Store ──
// Persistent memory layer — agents retrieve relevant knowledge before acting.
// Supports multiple memory types: fact | policy | preference | history | summary
model AiMemory {
  id              String    @id @default(cuid())
  organizationId  String
  agentId         String?
  // If agentId is null, this is org-wide knowledge (accessible to all agents)
  // fact | policy | preference | history | summary | customer | product | campaign | financial
  type            String
  // Short title for retrieval (e.g., "Refund policy for digital products")
  title           String
  // Full content — the actual knowledge
  content         String    @db.Text
  // JSON: tags for semantic search/filtering
  tags            String    @default("[]") @db.Text
  // JSON: metadata (source, confidence, expiresAt, etc.)
  metadata        String    @default("{}") @db.Text
  // Importance 0-100 — higher = more likely to be retrieved
  importance      Int       @default(50)
  // Auto-expire old memories (null = never expires)
  expiresAt       DateTime?
  // Access count — incremented when an agent retrieves this memory
  accessCount     Int       @default(0)
  lastAccessedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agent           AiAgent?  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@index([agentId])
  @@index([organizationId, importance])
}

// ── AI Workflow Definition ──
// A reusable multi-step process that orchestrates multiple agents.
// e.g., "New Order Workflow" — Operations → Finance → Marketing → Analytics → CEO
model AiWorkflow {
  id              String    @id @default(cuid())
  organizationId  String
  // Stable key — "new_order", "low_inventory_alert", "weekly_summary"
  workflowKey     String
  name            String
  description     String    @default("")
  // Trigger type — manual | event | schedule
  // event triggers: order_created, inventory_low, customer_angry, weekly_summary_due
  // schedule triggers: daily, weekly, monthly
  trigger         String    @default("manual")
  // JSON: trigger config (e.g., for schedule: { cron: "0 9 * * 1" })
  triggerConfig   String    @default("{}") @db.Text
  // JSON: initial input shape — describes what the workflow expects
  inputSchema     String    @default("{}") @db.Text
  isEnabled       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps           AiWorkflowStep[]
  executions      AiWorkflowExecution[]

  @@unique([organizationId, workflowKey])
  @@index([organizationId, trigger])
  @@index([organizationId, isEnabled])
}

// ── AI Workflow Step ──
// Each step in a workflow — assigned to one agent with defined input/output.
model AiWorkflowStep {
  id              String    @id @default(cuid())
  workflowId      String
  // Order of execution (1, 2, 3, ...)
  order           Int
  // The agent responsible for this step (by agentKey, e.g., "operations")
  agentKey        String
  agentId         String?
  name            String
  description     String    @default("")
  // JSON: template for the task input — can reference previous step outputs
  // e.g., { "orderId": "{{step1.output.orderId}}" }
  inputTemplate   String    @default("{}") @db.Text
  // Condition to skip this step — JS expression string, evaluated at runtime
  // e.g., "step1.output.paymentVerified === true"
  skipCondition   String?
  // Whether this step requires Owner approval before execution
  requiresApproval Boolean  @default(false)
  // Timeout in seconds (0 = no timeout)
  timeoutSeconds  Int       @default(300)
  createdAt       DateTime  @default(now())

  workflow        AiWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  agent           AiAgent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([workflowId, order])
  @@index([agentId])
}

// ── AI Workflow Execution ──
// A single run of a workflow — tracks state and links to all task instances.
model AiWorkflowExecution {
  id              String    @id @default(cuid())
  organizationId  String
  workflowId      String
  // running | completed | failed | cancelled | paused (awaiting approval)
  status          String    @default("running")
  // JSON: input data passed to the workflow
  input           String    @default("{}") @db.Text
  // JSON: final output / summary
  output          String    @default("{}") @db.Text
  // Current step number being executed (1-indexed)
  currentStep     Int       @default(1)
  // Total steps in the workflow (cached from definition for quick UI display)
  totalSteps      Int       @default(0)
  // If paused for approval, link to the approval request
  approvalRequestId String?
  errorMessage    String?   @db.Text
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  // Duration in ms (set when completed)
  durationMs      Int?

  workflow        AiWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks           AiTask[]

  @@index([organizationId, status])
  @@index([workflowId, status])
  @@index([startedAt])
}

// ── AI Action Log ──
// Audit trail of EVERY action taken by any AI agent. Immutable. Required for
// compliance and for the Owner's "View all agent conversations" control.
model AiActionLog {
  id              String    @id @default(cuid())
  organizationId  String
  agentId         String?
  // Action type — task_created | task_completed | message_sent | decision_made |
  // approval_requested | approval_granted | approval_denied | workflow_started |
  // workflow_step_completed | workflow_completed | memory_updated |
  // spending_occurred | error | escalation | config_changed
  actionType      String
  // Human-readable description of what happened
  description     String
  // JSON: structured details (taskId, messageId, amount, reason, etc.)
  details         String    @default("{}") @db.Text
  // The reason/justification the agent gave for this action
  reason          String    @default("") @db.Text
  // If this action involved spending, the amount (for spending limit tracking)
  amount          Decimal?  @db.Decimal(12, 2)
  // The user who triggered this action (null if autonomous)
  triggeredByUserId String?
  // IP address (if action was triggered by an API call)
  ipAddress       String?
  createdAt       DateTime  @default(now())

  agent           AiAgent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([agentId, createdAt])
  @@index([actionType])
}

// ── AI Approval Request ──
// When an agent wants to perform a sensitive action (financial transfer,
// record deletion, config change, etc.), it creates an approval request.
// The Owner approves or denies. The action is NOT executed until approved.
model AiApprovalRequest {
  id              String    @id @default(cuid())
  organizationId  String
  requestedByAgentId String
  // The type of action being requested — financial_transfer | record_deletion |
  // config_change | external_api_credential_change | major_decision | custom
  actionType      String
  title           String
  description     String    @db.Text
  // JSON: the full proposed action with all parameters
  proposedAction  String    @default("{}") @db.Text
  // The agent's reasoning for why this action is needed
  reasoning       String    @default("") @db.Text
  // If approved, the actual action payload to execute
  approvedAction  String?   @db.Text
  // pending | approved | denied | expired | executed | failed
  status          String    @default("pending")
  // The Owner user who approved/denied
  reviewedByUserId String?
  reviewerNote    String?   @db.Text
  // Auto-expire pending requests after this time
  expiresAt       DateTime?
  reviewedAt      DateTime?
  executedAt      DateTime?
  executionResult String?   @db.Text
  errorMessage    String?   @db.Text
  // Optional link to a task that triggered this approval
  taskId          String?
  createdAt       DateTime  @default(now())

  requestedByAgent AiAgent  @relation("ApprovalRequestedBy", fields: [requestedByAgentId], references: [id], onDelete: Cascade)
  task            AiTask?   @relation("ApprovalForTask", fields: [taskId], references: [id], onDelete: SetNull)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([requestedByAgentId])
  @@index([expiresAt])
}

// ── AI Automation Rule ──
// Declarative rules for auto-actions (auto-reply to common questions, auto-
// generate daily reports, etc.). The orchestrator evaluates these on events.
model AiAutomationRule {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  description     String    @default("")
  // Trigger event — customer_message | low_inventory | angry_customer |
  // daily_summary | weekly_summary | monthly_summary | new_lead | new_order
  trigger         String
  // JSON: trigger conditions (e.g., { keywords: ["refund", "return"], threshold: 5 })
  conditions      String    @default("{}") @db.Text
  // The agentKey that should handle this rule
  agentKey        String
  // JSON: action to take — { type: "auto_reply", template: "...", escalateIfComplex: true }
  action          String    @default("{}") @db.Text
  // Whether to escalate to Owner if the rule's confidence is low
  escalateOnLowConfidence Boolean @default(true)
  // Confidence threshold 0-1 — below this, escalate instead of auto-acting
  confidenceThreshold Float @default(0.7)
  isEnabled       Boolean   @default(true)
  // Stats
  triggerCount    Int       @default(0)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, trigger, isEnabled])
  @@index([agentKey])
}
